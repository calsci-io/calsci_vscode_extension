{
  "name": "calsci-vscode-extension",
  "displayName": "CalSci",
  "description": "Run MicroPython on CalSci with a persistent REPL, interactive and non-interactive execution, workspace sync, and bundled firmware flashing.",
  "version": "0.1.0",
  "publisher": "calsci-io",
  "author": "Rupesh Verma",
  "license": "MIT",
  "icon": "media/calsci-marketplace-icon.png",
  "homepage": "https://calsci.io",
  "bugs": {
    "url": "https://calsci.io",
    "email": "contact@calsci.io"
  },
  "galleryBanner": {
    "color": "#050505",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "calsci",
    "micropython",
    "serial",
    "repl",
    "embedded",
    "firmware",
    "esp32",
    "python",
    "usb",
    "calculator"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:calsci.softResetDevice",
    "onCommand:calsci.selectDevice",
    "onCommand:calsci.openTerminal",
    "onCommand:calsci.runCurrentFile",
    "onCommand:calsci.runInteractiveFile",
    "onCommand:calsci.syncFolder",
    "onCommand:calsci.fetchWorkspace",
    "onCommand:calsci.fetchWorkspacePartial",
    "onCommand:calsci.clearAllFiles",
    "onCommand:calsci.flashFirmware",
    "onCommand:calsci.eraseChip",
    "onCommand:calsci.refreshWorkspace",
    "onCommand:calsci.refreshTestingFolder",
    "onCommand:calsci.openHybridPanel"
  ],
  "main": "out/extension.js",
  "files": [
    "out/**",
    "backend/**",
    "firmware/**",
    "runtime/**",
    "media/**",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SUPPORT.md"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "calsciSidebar",
          "title": "CalSci",
          "icon": "media/calsci.svg"
        }
      ]
    },
    "views": {
      "calsciSidebar": [
        {
          "id": "calsci.actionsView",
          "name": "Actions"
        },
        {
          "id": "calsci.workspaceView",
          "name": "CalSci Workspace"
        },
        {
          "id": "calsci.testingView",
          "name": "Testing Folder"
        }
      ]
    },
    "commands": [
      {
        "command": "calsci.softResetDevice",
        "title": "CalSci: Soft Reset Device",
        "icon": {
          "light": "media/reset.svg",
          "dark": "media/reset.svg"
        }
      },
      {
        "command": "calsci.selectDevice",
        "title": "CalSci: Select Device"
      },
      {
        "command": "calsci.runCurrentFile",
        "title": "CalSci: Run Non-Interactive File",
        "icon": {
          "light": "media/run.svg",
          "dark": "media/run.svg"
        }
      },
      {
        "command": "calsci.runInteractiveFile",
        "title": "CalSci: Run Interactive File",
        "icon": {
          "light": "media/run-interactive.svg",
          "dark": "media/run-interactive.svg"
        }
      },
      {
        "command": "calsci.openTerminal",
        "title": "CalSci: Open Terminal",
        "icon": {
          "light": "media/chip.svg",
          "dark": "media/chip.svg"
        }
      },
      {
        "command": "calsci.syncFolder",
        "title": "CalSci: Sync Folder"
      },
      {
        "command": "calsci.fetchWorkspace",
        "title": "CalSci: Fetch All Files"
      },
      {
        "command": "calsci.fetchWorkspacePartial",
        "title": "CalSci: Partial Fetch"
      },
      {
        "command": "calsci.refreshTestingFolder",
        "title": "CalSci: Refresh Testing Folder",
        "icon": {
          "light": "media/reset.svg",
          "dark": "media/reset.svg"
        }
      },
      {
        "command": "calsci.clearAllFiles",
        "title": "CalSci: Clear All Files",
        "icon": {
          "light": "media/reset.svg",
          "dark": "media/reset.svg"
        }
      },
      {
        "command": "calsci.flashFirmware",
        "title": "CalSci: Flash Firmware"
      },
      {
        "command": "calsci.eraseChip",
        "title": "CalSci: Erase Chip",
        "icon": {
          "light": "media/erase.svg",
          "dark": "media/erase.svg"
        }
      },
      {
        "command": "calsci.refreshWorkspace",
        "title": "CalSci: Refresh Workspace",
        "icon": {
          "light": "media/reset.svg",
          "dark": "media/reset.svg"
        }
      },
      {
        "command": "calsci.openHybridPanel",
        "title": "CalSci: Open Hybrid Panel",
        "icon": {
          "light": "media/calsci.svg",
          "dark": "media/calsci.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "calsci.openHybridPanel",
          "when": "view == calsci.actionsView",
          "group": "navigation@1"
        },
        {
          "command": "calsci.softResetDevice",
          "when": "view == calsci.actionsView",
          "group": "navigation@2"
        },
        {
          "command": "calsci.flashFirmware",
          "when": "view == calsci.actionsView",
          "group": "navigation@3"
        },
        {
          "command": "calsci.eraseChip",
          "when": "view == calsci.actionsView",
          "group": "navigation@4"
        },
        {
          "command": "calsci.runCurrentFile",
          "when": "view == calsci.actionsView",
          "group": "navigation@5"
        },
        {
          "command": "calsci.runInteractiveFile",
          "when": "view == calsci.actionsView",
          "group": "navigation@6"
        },
        {
          "command": "calsci.openTerminal",
          "when": "view == calsci.actionsView",
          "group": "navigation@7"
        },
        {
          "command": "calsci.refreshWorkspace",
          "when": "view == calsci.workspaceView",
          "group": "navigation@1"
        },
        {
          "command": "calsci.refreshTestingFolder",
          "when": "view == calsci.testingView",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "calsci.syncFolder",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "configuration": {
      "title": "CalSci",
      "properties": {
        "calsci.resetTimeoutSeconds": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "Timeout for waiting CalSci prompt after soft reset."
        },
        "calsci.runTimeoutSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 600,
          "description": "Timeout for running active Python file on CalSci. Set to 0 to disable the timeout."
        },
        "calsci.autoConnectOnDetect": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open a CalSci session when a detected device matches the current selection."
        },
        "calsci.autoScanWorkspace": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan the device workspace when the CalSci Workspace view is opened. Disable to require manual refresh."
        }
      }
    }
  },
  "scripts": {
    "stage-runtime": "python3 scripts/stage_runtime.py",
    "build": "npm run stage-runtime && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run build",
    "package:vsix": "npm run build && npx @vscode/vsce package --allow-missing-repository --no-dependencies --no-yarn"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.26.0",
    "typescript": "^5.6.3"
  }
}
